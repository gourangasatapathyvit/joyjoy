# secrets / local state
.env
*.env.local
data/
webui-state/
*.sqlite
*.sqlite-*
config/*.local.json
# global model catalog (holds literal API keys):
config/models.json

# python
__pycache__/
*.pyc
.venv/
.mypy_cache/
