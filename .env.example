# joyjoy backend - example env. Copy to .env and fill in real values.
# Never commit .env. Keep generated secrets stable once the app has data.

# ---- Runtime ----
APP_ENV=dev                       # dev | prod
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5173

# ---- Gateway/dev identity ----
GATEWAY_API_KEY=
USER_ID_HEADER=X-User-Id
THREAD_ID_HEADER=X-Thread-Id
DEV_USERNAME=dev-user

# ---- Auth: session cookie + password-reset OTP ----
JWT_SECRET=
JWT_ALGORITHMS=HS256
JWT_AUDIENCE=
SESSION_COOKIE=joyjoy_session
SESSION_TTL_HOURS=720
OTP_TTL_MINUTES=10
APP_PUBLIC_NAME=joyjoy

# ---- SMTP (optional; unset logs OTPs in dev instead of emailing) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_STARTTLS=true

# ---- Postgres (prod) ----
# APP_ENV selects the active DB mode. DATABASE_URL overrides the DB_* parts below.
DB_HOSTER=0 # 1 = server-hosted Postgres (prod); 0 = local postgres server (dev). APP_ENV=prod implies DB_HOSTER=1.
DB_PROVIDER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
LANGGRAPH_CHECKPOINT_DB=langgraph_db
DATABASE_URL=
PG_POOL_MAX=20
JOYJOY_INTERRUPT_TOOLS=

# ---- Dev local persistence ----
SQLITE_CHECKPOINT_PATH=./data/dev_checkpoints.sqlite
USER_DATA_ROOT=./data/users
APP_DB_PATH=./data/joyjoy.db
WORKSPACE_ROOT=./data/workspaces
# DEV-ONLY: extra allow-list roots for serving absolute MEDIA: paths outside the
# workspace (comma-separated; ~ expanded). Ignored when APP_ENV=prod. Empty = workspace only.
# Example (WSL+Windows): MEDIA_DEV_EXTRA_ROOTS=~,/mnt/c/Users
MEDIA_DEV_EXTRA_ROOTS=

# ---- Skills / MCP ----
# Global skills and MCP servers are seeded into the DB from global_seed.sql.
# MCP secrets should be referenced as ${VAR} in DB rows; real values live here.

# ---- Azure OpenAI base-model API key ----
# The seeded global/base models reference ${AZURE_OPENAI_API_KEY} at runtime.
AZURE_OPENAI_API_KEY=

# Optional legacy Azure fallback settings.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=o4-mini
AZURE_OPENAI_MODEL=o4-mini

# Optional legacy model catalog settings; current global models live in the DB.
JOYJOY_MODELS_JSON=
JOYJOY_GLOBAL_MODELS=

# ---- Optional provider fallback credentials ----
# Used only when a Bedrock model has no per-model AWS keys configured.
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# ---- Optional tools ----
TAVILY_API_KEY=

# ---- Credentials table encryption ----
# Fernet key. Generate once and keep stable; rotating it orphans encrypted secrets.
CREDENTIAL_ENCRYPTION_KEY=

# ---- OpenSandbox (optional per-session execution sandbox) ----
# To enable under docker compose: set SANDBOX_ENABLED=true AND COMPOSE_PROFILES=sandbox
# (the profile builds the sandbox image + starts the opensandbox server service; the
# backend then talks to it at SANDBOX_SERVER_DOMAIN=opensandbox:8090). Leave both unset
# for host workspace mode. Dev (scripts/start_all.sh) runs the server on the host at
# 127.0.0.1:8090 instead — use that value there.
SANDBOX_ENABLED=false
OPENSANDBOX_API_KEY=
SANDBOX_SERVER_DOMAIN=127.0.0.1:8090
SANDBOX_SERVER_PROTOCOL=http
# Proxy sandbox traffic through the server instead of connecting to each sandbox
# directly. Set true for docker-compose / any deployment where the backend can't
# reach the per-sandbox container network (compose already defaults this to true).
# Leave false for the host dev path (scripts/start_all.sh) — direct is faster.
SANDBOX_USE_SERVER_PROXY=false
SANDBOX_IMAGE=joyjoy/sandbox-fat:4
SANDBOX_CPU=1
SANDBOX_MEMORY=2Gi
SANDBOX_TIMEOUT_MINUTES=30
SANDBOX_IDLE_MINUTES=15
SANDBOX_MAX_LIVE=16
SANDBOX_VOLUME_PREFIX=joyjoy-ws-
SANDBOX_MOUNT_PATH=/workspace

# ---- Observability (optional: metrics + tracing) ----
# Prometheus metrics at /metrics (+ agent/HTTP instrumentation). Scrape it with the
# bundled Prometheus/Grafana under COMPOSE_PROFILES=observability, or your own.
METRICS_ENABLED=false
# Distributed tracing: deepagents runs on LangChain, so traces are captured with no
# code and sent to self-hosted Langfuse. TWO transports (pick by what you set below):
TRACING_ENABLED=false
OTEL_SERVICE_NAME=joyjoy-backend
#
# (A) PREFERRED — Langfuse LangChain callback. Gives NATIVE per-user + per-session
#     (session-label) views: each trace carries langfuse_user_id (the tenant) and
#     langfuse_session_id (the chat/thread). With the `observability` profile these
#     keys auto-provision the Langfuse project on first boot (LANGFUSE_INIT_*), so the
#     dev defaults below work out of the box; rotate them for prod. UI login (:3000) =
#     admin@joyjoy.local / joyjoyadmin (LANGFUSE_INIT_USER_*).
LANGFUSE_PUBLIC_KEY=pk-lf-joyjoy-dev
LANGFUSE_SECRET_KEY=sk-lf-joyjoy-dev
LANGFUSE_HOST=http://langfuse-web:3000   # host (non-compose): http://localhost:3000
#
# (B) FALLBACK — vendor-neutral OTLP (also works with Tempo/Jaeger). Used only if the
#     LANGFUSE_* keys above are empty. user/thread arrive as metadata, not native
#     fields. Basic auth = base64(public_key:secret_key):
#       python -c "import base64;print(base64.b64encode(b'pk-lf-...:sk-lf-...').decode())"
# OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse-web:3000/api/public/otel
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(public_key:secret_key)>

# ---- Self-hosted Langfuse stack (only used by COMPOSE_PROFILES=observability) ----
# Generated-once secrets for the bundled Langfuse services (web/worker/clickhouse/
# redis/minio/postgres). Keep stable once it has data.
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_SALT=changeme-langfuse-salt
LANGFUSE_ENCRYPTION_KEY=                 # 64 hex chars: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=                # openssl rand -base64 32
LANGFUSE_CLICKHOUSE_PASSWORD=clickhouse
LANGFUSE_REDIS_PASSWORD=redis
LANGFUSE_MINIO_PASSWORD=miniosecret
# Grafana admin password for the bundled dashboards.
GRAFANA_ADMIN_PASSWORD=admin

COMPOSE_PROFILES=sandbox
# COMPOSE_PROFILES=sandbox,localdb
# COMPOSE_PROFILES=sandbox,localdb,observability