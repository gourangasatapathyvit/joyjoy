# joyjoy backend — example env. Copy to .env and fill in real values.

# ---- Runtime ----
APP_ENV=dev                       # dev | prod
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Gateway auth (hermes-webui -> backend) ----
GATEWAY_API_KEY=change-me
USER_ID_HEADER=X-User-Id
THREAD_ID_HEADER=X-Thread-Id
DEV_DEFAULT_USER=dev-user

# ---- Per-user JWT (direct clients / prod) ----
JWT_SECRET=
JWT_ALGORITHMS=HS256
JWT_AUDIENCE=

# ---- Postgres (PROD) ----
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
LANGGRAPH_CHECKPOINT_DB=langgraph_db
DATABASE_URL=

# ---- Dev local persistence ----
SQLITE_CHECKPOINT_PATH=./data/dev_checkpoints.sqlite
USER_DATA_ROOT=./data/users

# ---- Skills / MCP ----
GLOBAL_SKILLS_DIR=./skills/global
MCP_GLOBAL_CONFIG=./config/global.mcp.json

# ---- Azure OpenAI ----
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=o4-mini
AZURE_OPENAI_MODEL=o4-mini

# ---- Optional ----
TAVILY_API_KEY=
CREDENTIAL_ENCRYPTION_KEY=
